import requests

class WeatherApp:
    def __init__(self, ort):
        self.ort = ort
        self.url = f"https://wttr.in/{self.ort}?format=j1"
        try:
            self.data = requests.get(self.url).json()
        except:
            self.data = None

    def temperature(self):
        if self.data == None:
            print("Dieser Ort existiert nicht.")
        else:
            for key, value in self.data["current_condition"][0].items():
                if key == "temp_C":
                    temperature = value
                if key == "observation_time":
                    time = value
            print(f"Temperatur in {self.ort} um {time}: {temperature}°C")

    def forecast(self):
        if self.data == None:
            print("Dieser Ort existiert nicht.")
        else:
            for key, value in self.data["weather"][1].items():
                if key == "maxtempC":
                    tomorrowTemp = value
            print(f"Temperatur morgen: {tomorrowTemp}°C")

weather = WeatherApp(input("Ort: "))
weather.temperature()
weather.forecast()
