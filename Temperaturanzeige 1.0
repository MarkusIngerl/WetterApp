import requests

class WeatherApp:
    def __init__(self, town):
        self.town = town
        self.url = f"https://wttr.in/{self.town}?format=j1"
        try:
            self.data = requests.get(self.url).json()
        except:
            self.data = None
            print(f"{self.town} isn't existing!")

    def temperature(self):
        if self.data == None:
            print("-")
        else:
            current = self.data["current_condition"][0]
            temperature = current["temp_C"]
            time = current["observation_time"]
            print(f"Temperature in {self.town} at {time}: {temperature}°C")

    def forecast(self):
        if self.data == None:
            print("-")
        else:
            tomorrow = self.data["weather"][1]
            tomorrowTemp = tomorrow["maxtempC"]
            print(f"Temperature tomorrow: {tomorrowTemp}°C")

weather = WeatherApp(input("Town: "))
weather.temperature()
weather.forecast()
